# FORJA local/pre-cloud environment template.
# Copy to .env for local use. Do not commit real secrets.

FORJA_APP_NAME=forja-backend
FORJA_APP_VERSION=0.1.0
FORJA_APP_ENV=local
FORJA_DEBUG=true
FORJA_LOG_LEVEL=INFO

# Local-only bootstrap credentials. Replace before any non-local environment.
FORJA_ADMIN_USERNAME=forja_admin
FORJA_ADMIN_PASSWORD=change-this-local-bootstrap-password
FORJA_JWT_SECRET=change-this-local-jwt-secret-at-least-32-chars
FORJA_JWT_ALGORITHM=HS256
FORJA_JWT_EXP_MINUTES=60

# Local frontend origins only.
FORJA_FRONTEND_ORIGIN=http://localhost:5173
FORJA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local PostgreSQL. Create this DB locally before enabling migration checks:
# createdb forja_local
FORJA_DATABASE_URL=postgresql+asyncpg://forja:forja@127.0.0.1:5432/forja_local
FORJA_DB_AUTO_MIGRATE=false
